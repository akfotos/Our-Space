rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userCoupleId(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.coupleId;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isInCouple(coupleId) {
      return isSignedIn() && userCoupleId(request.auth.uid) == coupleId;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /couples/{coupleId} {
      allow read, write: if isInCouple(coupleId);
    }

    match /couples/{coupleId}/{collection}/{docId} {
      allow read, write: if isInCouple(coupleId);
    }

    match /userLocations/{uid} {
      allow read: if isSignedIn() && resource.data.coupleId == userCoupleId(request.auth.uid);
      allow create, update: if isOwner(uid) && request.resource.data.coupleId == userCoupleId(request.auth.uid);
      allow delete: if isOwner(uid);
    }
  }
}