{
  "rules": {
    "chat": {
      "$coupleId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["timestamp"]
        },
        "typing": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        },
        "missYou": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "playerState": {
      "$coupleId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "presence": {
      "$coupleId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.hasChildren(['online', 'lastSeen', 'name'])"
        }
      }
    }
  }
}